rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         request.auth.token.email == "ambriautopecas@gmail.com");
    }

    match /users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isAdmin());
      allow write: if isAuthenticated() && (request.auth.uid == uid || isAdmin());
    }

    match /appointments/{appointmentId} {
      allow read: if isAuthenticated() && (isAdmin() || ('userId' in resource.data && resource.data.userId == request.auth.uid));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (isAdmin() || ('userId' in resource.data && resource.data.userId == request.auth.uid));
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /professionals/{professionalId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /taxidog/{requestId} {
      allow read: if isAuthenticated() && (isAdmin() || ('userId' in resource.data && resource.data.userId == request.auth.uid));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (isAdmin() || ('userId' in resource.data && resource.data.userId == request.auth.uid));
      allow delete: if isAdmin();
    }
    
    match /taxi_requests/{requestId} {
      allow read: if isAuthenticated() && (isAdmin() || ('userId' in resource.data && resource.data.userId == request.auth.uid));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (isAdmin() || ('userId' in resource.data && resource.data.userId == request.auth.uid));
      allow delete: if isAdmin();
    }
    
    match /sales/{saleId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if isAdmin();
    }
    
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (isAdmin() || ('userId' in resource.data && resource.data.userId == request.auth.uid));
      allow create: if isAdmin();
      allow update: if isAuthenticated() && (isAdmin() || ('userId' in resource.data && resource.data.userId == request.auth.uid));
      allow delete: if isAdmin();
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
